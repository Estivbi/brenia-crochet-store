---
// src/pages/productos/index.astro
import Layout from '../../components/Layout.astro';
---

<Layout
  title="Productos"
  description="Descubre nuestra colección de bolsos de crochet hechos a mano. Piezas únicas y artesanales, disponibles para encargar por WhatsApp."
>
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-widest text-stone-500 mb-3">
        Colección
      </span>
      <h1 class="text-4xl sm:text-5xl font-semibold text-stone-800 leading-tight mb-6">
        Nuestros productos
      </h1>
      <p class="text-lg text-stone-600 max-w-xl mx-auto">
        Estamos preparando nuestra colección. Mientras tanto, escríbenos por
        WhatsApp para conocer las piezas disponibles.
      </p>
    </div>
  </section>
</Layout>
