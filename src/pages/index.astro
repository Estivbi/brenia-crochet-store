---
// src/pages/index.astro
import Layout from '../components/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Philosophy from '../components/sections/Philosophy.astro';
import ProductGrid from '../components/sections/ProductGrid.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';
---

<Layout
  title="Brenia Crochet"
  description="Bolsos de crochet hechos a mano con amor y dedicación artesanal. Piezas únicas, minimalistas y elegantes. Encarga el tuyo por WhatsApp."
>
  <Hero />
  <ProductGrid />
  <Philosophy />

  <!-- Floating WhatsApp button (global) -->
  <WhatsAppButton variant="floating" />
</Layout>
