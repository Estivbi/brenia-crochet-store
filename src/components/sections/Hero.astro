---
// src/components/sections/Hero.astro
import WhatsAppButton from '../ui/WhatsAppButton.astro';
---

<section class="relative py-20 sm:py-28 px-4 sm:px-6 lg:px-8 overflow-hidden bg-stone-50">
  <!-- Decorative background gradient -->
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-br from-stone-100 via-stone-50 to-white"
    aria-hidden="true"
  ></div>

  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text content -->
      <div class="order-2 lg:order-1 text-center lg:text-left">
        <span class="inline-block text-xs font-semibold uppercase tracking-widest text-stone-500 mb-4">
          Hecho a mano · Con amor
        </span>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-stone-800 leading-tight mb-6">
          Bolsos de Crochet<br />
          <span class="text-stone-500">únicos, hechos con amor</span>
        </h1>

        <p class="text-lg sm:text-xl text-stone-600 max-w-xl mx-auto lg:mx-0 mb-10 leading-relaxed">
          Cada pieza cuenta una historia. Artesanía moderna para mujeres auténticas
          que buscan algo verdaderamente único.
        </p>

        <!-- Dual CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="#productos"
            class="inline-flex items-center justify-center px-6 py-3 bg-stone-800 text-white rounded-full font-medium hover:bg-stone-700 active:bg-stone-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-800 transition-all duration-200"
          >
            Ver Colección
          </a>
          <WhatsAppButton
            variant="secondary"
            size="md"
            customMessage="¡Hola! Me interesan vuestros bolsos de crochet artesanales. ¿Podéis contarme más?"
          />
        </div>
      </div>

      <!-- Hero image -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div
          class="relative w-72 h-72 sm:w-96 sm:h-96 rounded-3xl overflow-hidden shadow-xl bg-stone-200"
          aria-hidden="true"
        >
          <!-- Placeholder illustration (replace with real product image) -->
          <div class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-br from-stone-200 to-stone-300">
            <svg
              class="w-24 h-24 text-stone-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            <span class="text-stone-500 text-sm font-medium">Bolso artesanal</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
