---
// src/components/Footer.astro
import { WHATSAPP_PHONE } from '../config';

const year = new Date().getFullYear();
const waHref = `https://wa.me/${WHATSAPP_PHONE}?text=${encodeURIComponent('¡Hola! Me gustaría obtener más información sobre vuestros bolsos de crochet')}`;
---

<footer class="bg-white border-t border-stone-200 mt-16">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <div class="w-8 h-8 bg-gradient-to-br from-stone-600 to-stone-800 rounded-full flex items-center justify-center">
            <span class="text-white font-semibold text-sm">B</span>
          </div>
          <span class="text-xl font-semibold text-stone-800">Brenia Crochet</span>
        </div>
        <p class="text-stone-600 text-sm leading-relaxed">
          Bolsos de crochet únicos, hechos a mano con amor y dedicación artesanal.
          Cada pieza cuenta una historia.
        </p>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="font-semibold text-stone-800 mb-4">Enlaces</h3>
        <ul class="space-y-2">
          <li>
            <a href="/productos" class="text-stone-600 hover:text-stone-800 transition-colors duration-200 text-sm">
              Productos
            </a>
          </li>
          <li>
            <a href="/sobre-nosotros" class="text-stone-600 hover:text-stone-800 transition-colors duration-200 text-sm">
              Sobre Nosotros
            </a>
          </li>
          <li>
            <a href="/envios" class="text-stone-600 hover:text-stone-800 transition-colors duration-200 text-sm">
              Envíos y Devoluciones
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-semibold text-stone-800 mb-4">Contacto</h3>
        <a
          href={waHref}
          class="inline-flex items-center space-x-2 text-green-600 hover:text-green-700 transition-colors duration-200 text-sm"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
          </svg>
          <span>Escríbenos por WhatsApp</span>
        </a>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-stone-200 text-center text-stone-500 text-sm">
      <p>&copy; {year} Brenia Crochet. Hecho con ❤️ de forma artesanal.</p>
    </div>
  </div>
</footer>
