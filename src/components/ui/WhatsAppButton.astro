---
// src/components/ui/WhatsAppButton.astro
import { WHATSAPP_PHONE } from '../../config';
import { buildWhatsAppUrl, buildWhatsAppMessage } from '../../utils/whatsapp';

export interface Props {
  variant?: 'primary' | 'secondary' | 'floating' | 'icon-only';
  size?: 'sm' | 'md' | 'lg';
  productName?: string;
  currentURL?: string;
  customMessage?: string;
  phoneNumber?: string;
  className?: string;
}

const {
  variant = 'primary',
  size = 'md',
  productName,
  currentURL,
  customMessage,
  phoneNumber = WHATSAPP_PHONE,
  className = '',
} = Astro.props;

const message = buildWhatsAppMessage({ productName, currentURL, customMessage });
const whatsappUrl = buildWhatsAppUrl(phoneNumber, message);

const ariaLabel = productName
  ? `Consultar por WhatsApp sobre ${productName}`
  : 'Consultar por WhatsApp';

// Size modifiers (not used for floating/icon-only which have fixed sizes)
const sizeClasses: Record<string, string> = {
  sm: 'px-3 py-1.5 text-sm gap-1.5',
  md: 'px-5 py-2.5 text-base gap-2',
  lg: 'px-6 py-3 text-lg gap-2.5',
};

const iconSize: Record<string, string> = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};
---

{variant === 'primary' && (
  <a
    href={whatsappUrl}
    class={`inline-flex items-center justify-center rounded-full font-medium bg-green-600 text-white hover:bg-green-700 active:bg-green-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 transition-all duration-200 ${sizeClasses[size]} ${className}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={ariaLabel}
  >
    <svg class={`${iconSize[size]} shrink-0`} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
    </svg>
    <span>{productName ? `Consultar sobre ${productName}` : 'Encargar por WhatsApp'}</span>
  </a>
)}

{variant === 'secondary' && (
  <a
    href={whatsappUrl}
    class={`inline-flex items-center justify-center rounded-full font-medium border-2 border-green-600 text-green-700 bg-transparent hover:bg-green-50 active:bg-green-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 transition-all duration-200 ${sizeClasses[size]} ${className}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={ariaLabel}
  >
    <svg class={`${iconSize[size]} shrink-0`} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
